<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="view_product_product_form_inherit" model="ir.ui.view">
            <field name="name">product.product.form.inherit.warehouse.group</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">

                <xpath expr="//button[@name='action_open_label_layout']" position="after">
                    <button name="generarReglasAbastecimiento" type="object" class="btn btn-primary">Actualizar Reglas</button>
                    
                
                </xpath>
                

                <xpath expr="//field[@name='categ_id']" position="after">
                    <field name="warehouse_group_id"/>
                </xpath>


            </field>
        </record>

        

    </data>
</odoo>
