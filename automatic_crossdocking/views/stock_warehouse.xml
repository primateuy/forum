<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_stock_warehouse" model="ir.ui.view">
            <field name="name">stock.warehouse.form.crossdock</field>
            <field name="model">stock.warehouse</field>
            <field name="inherit_id" ref="stock.view_warehouse"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='wh_output_stock_loc_id']" position="after">
                    <separator string="Configuración Crossdocking" colspan="2"/>
                    <field name="crossdocking_location_id" colspan="2"/>
                    <field name="crossdocking_reception_type_id" colspan="2"/>
                    <field name="crossdocking_type_id" colspan="2"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
