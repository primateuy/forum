<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_crossdock_distribution_wizard" model="ir.ui.view">
    <field name="name">crossdock.distribution.wizard.form</field>
    <field name="model">crossdock.distribution.wizard</field>
    <field name="arch" type="xml">
        <form string="Editar distribución de Crossdock">
            <field name="line_ids">
                <tree editable="bottom">
                    <field name="product" />
                    <field name="cantidadAlmacenPrincipal"/>
                    <field name="cantidadAlmacenesSecundarios"/>
                    <field name="almacenPrincipal" />
                </tree>
            </field>
            <footer>
                <button name="editarInformacion" class="oe_highlight" string="Guardar" type="object"/>
            </footer>
        </form>
    </field>
</record>


</odoo>

