<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_requisition_matrix_wizard_form" model="ir.ui.view">
        <field name="name">purchase.requisition.matrix.wizard.form</field>
        <field name="model">purchase.requisition.matrix.wizard</field>
        <field name="arch" type="xml">
            <form string="Seleccione las variantes del producto">
                <group>
                    <field name="requisition_id" invisible="1"/>
                    <field name="product_tmpl_id" options="{'no_create': True}"/>
                    <group string="Ejes de la matriz" col="3">
                        <field name="attribute_size_id" options="{'no_create': True}"/>
                        <field name="attribute_color_id" options="{'no_create': True}"/>
                        <field name="attribute_color2_id" options="{'no_create': True}"/>
                    </group>
                </group>
                <separator string="Carga por cuadrante"/>
                <field name="line_ids"
                       widget="x2many_2d_matrix"
                       field_x_axis="size_value_id"
                       field_y_axis="row_id"
                       field_value="qty">
                    <tree editable="bottom">
                        <field name="row_id"/>
                        <field name="size_value_id"/>
                        <field name="product_id"/>
                        <field name="qty"/>
                    </tree>
                </field>
                <footer>
                    <button string="Confirmar" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Descartar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
