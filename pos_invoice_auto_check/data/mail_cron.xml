<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="send_invoice" model="ir.cron">
            <field name="name">POS: Send Invoice By Email</field>
            <field name="model_id" ref="point_of_sale.model_res_config_settings" />
            <field name="state">code</field>
            <field name="active">False</field>
            <field name="numbercall">-1</field>

        </record>

        <record id="mail_template" model="mail.template">
            <field name="name">POS Invoice</field>
            <field name="model_id" ref="point_of_sale.model_pos_order" />
            <field name="subject">Invoice {{ object.name }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="body_html" type="html">
                <div style="margin: 0px; padding: 0px;">
                    <p style="margin: 0px; padding: 0px; font-size: 13px;"> Dear <t
                            t-if="object.partner_id.parent_id">
                            <t t-out="object.partner_id.name or ''" />(<t
                                t-out="object.partner_id.parent_id.name or ''" />), </t>
                        <t t-else="">
                            <t t-out="object.partner_id.name or ''" />, </t>
                        <br /><br /> Invoice
                        generated for you. <br /> Invoice Number:- <t
                            t-out="object.account_move.name" />
                        <br /> Total Amount:- <t
                            t-out="object.account_move.amount_total" />
                        <br /> Invoice Date:- <t
                            t-out="object.account_move.invoice_date" />
                        <br />
                        <br /> If you have any
                        questions, please contact us. <br /> Thank you for choosing <t
                            t-out="object.company_id.name" />
                        <br />
                        <br />
                        <t
                            t-out="object.company_id.street" />
                    </p>
                </div>
            </field>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="auto_delete" eval="True" />
        </record>
    </data>
</odoo>