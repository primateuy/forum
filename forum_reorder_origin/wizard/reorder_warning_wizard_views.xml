<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="forum_reorder_warning_wizard_form" model="ir.ui.view">
        <field name="name">forum.reorder.warning.wizard.form</field>
        <field name="model">forum.reorder.warning.wizard</field>
        <field name="arch" type="xml">
            <form string="Alerta de Stock en Origen">
                <group>
                    <div class="alert alert-warning" role="alert">
                        <i class="fa fa-warning" title="Stock insuficiente en origen"/> <strong>Stock insuficiente en origen</strong>
                    </div>
                    <field name="message" readonly="1" nolabel="1" widget="text"/>
                </group>
                <footer>
                    <button name="action_force_replenish"
                            string="Forzar Reabastecimiento"
                            type="object"
                            class="btn-primary"
                            confirm="En caso de que no hayan reglas que permitan abastecer (compras automáticas u otros locales), puede estar generando operaciones que no serán cumplidas. ¿Desea continuar?"/>
                    <button name="action_cancel"
                            string="Cancelar"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
