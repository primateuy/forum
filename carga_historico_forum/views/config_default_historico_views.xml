<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_config_default_historico_tree" model="ir.ui.view">
        <field name="name">config.default.historico.tree</field>
        <field name="model">config.default.historico</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="company_id"/>
                <field name="default_partner_id"/>
                <field name="default_product_id"/>
                <field name="default_journal_id"/>
                <field name="default_company_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_config_default_historico_form" model="ir.ui.view">
        <field name="name">config.default.historico.form</field>
        <field name="model">config.default.historico</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="default_company_id"/>
                            <field name="default_journal_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Defaults por partner">
                            <field name="default_partner_id"/>
                        </group>
                        <group string="Defaults por producto">
                            <field name="default_product_id"/>
                            <field name="default_tax_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_config_default_historico" model="ir.actions.act_window">
        <field name="name">Configuración Histórico</field>
        <field name="res_model">config.default.historico</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea una configuración para defaults de carga histórica.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_config_default_historico"
        name="Carga Histórico"
        parent="account.menu_finance_configuration"
        action="action_config_default_historico"
        sequence="210"
        groups="account.group_account_manager"
    />
</odoo>
