
<odoo>
    <record id="view_res_config_settings_auto_code_inventory" model="ir.ui.view">
        <field name="name">res.config.settings.inventory.auto.code</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='inventory_product_settings']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane">
                        <field name="product_code_template_auto"/>
                        <field name="product_code_variants_auto"/>
                        <field name="product_code_total_length"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="product_code_template_auto"/>
                        <div class="text-muted">
                            Genera códigos de producto y variantes. Prefijo = Categoría + Dominio.
                        </div>
                        <button type="action" string="Configurar dominios" name="%(action_product_code_domain)d" class="btn btn-link"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
