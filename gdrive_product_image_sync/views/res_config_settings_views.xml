<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.gdrive.sync</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Google Drive Image Sync" string="Google Drive Image Sync" name="gdrive_product_image_sync">
                    <block title="Google Drive Settings">
                        <setting string="Carpeta de Fotos Nuevas" help="ID de la carpeta de Google Drive donde se encuentran las fotos nuevas a procesar.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="gdrive_folder_id" placeholder="e.g. 1AbC_dEfGhIjKlMnOpQrStUvWxYz"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Mover imágenes después de sincronizar" help="Si está activo, las imágenes procesadas se moverán a la carpeta de destino. Desactivar para solo sincronizar sin mover archivos.">
                            <field name="gdrive_move_after_sync"/>
                        </setting>
                        <setting string="Carpeta de Fotos Procesadas" help="ID de la carpeta de Google Drive a la que se moverán las fotos una vez procesadas.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="gdrive_processed_folder_id"
                                           placeholder="e.g. 1AbC_dEfGhIjKlMnOpQrStUvWxYz"
                                           invisible="not gdrive_move_after_sync"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Service Account Credentials" help="Paste the full JSON content of your Google Service Account key file.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="gdrive_service_account_json" placeholder='{"type": "service_account", ...}'/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Sync Interval" help="How often (in minutes) the sync cron job runs.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="gdrive_sync_interval"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Batch Size" help="Cantidad de SKUs a procesar por lote. Valores menores reducen el uso de RAM.">
                            <div class="content-group">
                                <div class="mt16">
                                    <field name="gdrive_batch_size"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
