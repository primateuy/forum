<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_purchase_order_form_crossdock" model="ir.ui.view">
            <field name="name">purchase.order.form.crossdock</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_edit_crossdock_distribution"
                            type="object"
                            class="oe_stat_button"
                            invisible="not crossdock_enabled">
                        <div>Editar Distribución</div>
                    </button>
                </xpath>

                <xpath expr="//div[@name='date_planned_div']" position="after">
                    <field name="crossdock_enabled" invisible="context.get('hide_crossdock')"/>
                    <field name="crossdock_percentage" invisible="not crossdock_enabled"/>
                    <field name="distribution_rounding_method" invisible="not crossdock_enabled"/>
                </xpath>

                <xpath expr="//field[@name='product_qty']" position="after">
                    <field name="use_crossdock"/>
                    <field name="line_crossdock_percentage" widget="percentage" invisible="not use_crossdock"/>
                    <field name="distribution_multiple" invisible="not use_crossdock"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>