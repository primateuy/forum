<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record model="ir.ui.view" id="pos_invoice_flow">
			<field name="name">res.config.setting.form.extended.view</field>
			<field name="model">res.config.settings</field>
			<field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
			<field name="arch" type="xml">
				<xpath expr="//block[@id='pos_interface_section']" position="after">
					<h2 name="pos_inoice">POS Auto Invoice Configuration</h2>
					<div class="row mt16 o_settings_container">
						<div class="col-12 col-lg-6 o_setting_box">
							<div class="o_setting_left_pane">
								<field name="auto_check_invoice" />
							</div>
							<div class="o_setting_right_pane">
								<div>
									<label for="auto_check_invoice" />
									<div class="text-muted">
										POS Auto Check Invoice
									</div>
								</div>
							</div>
							<div class="o_setting_right_pane"
								invisible="auto_check_invoice == False">
								<div>
									<label for="auto_print_invoice" />
									<div class="content-group mt16">
										<field name="auto_print_invoice" colspan="4" nolabel="1"
											widget="radio" />
									</div>
								</div>
							</div>
						</div>
						<div class="col-12 col-lg-6 o_setting_box"
							invisible="auto_print_invoice=='disallow_auto_print_invoice' or not auto_check_invoice">
							<div class="o_setting_right_pane">
								<div>
									<label for="email_operation" />
									<div class="text-muted">
										Invoice Button Operation
									</div>
									<field name="email_operation" />
								</div>
							</div>
							<div class="o_setting_right_pane">
								<span class="o_form_label">Send By Email Cron</span>
								<div class="text-muted">
									Select Interval for cron and click on start/stop button to start
									or stop cron
								</div>
								<div class="content-group mt16">
									<field name="interval" class="col-lg-3 o_light_label" />
									<field name="email_period" class="col-lg-3" />
									<field name="start_email_service" invisible="1" />
									<field name="close_email_service" invisible="1" />
									<button name="start_mail_cron" type="object"
										string="Start" class="btn-primary"
										invisible="start_email_service" />
									<button name="stop_mail_cron" type="object"
										string="Stop" class="btn-primary"
										invisible="close_email_service" />
								</div>
							</div>
						</div>
					</div>

				</xpath>
			</field>
		</record>
		<record id="pos_order_view" model="ir.ui.view">
            <field name="name">pos.order.view</field>
            <field name="model">pos.order</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='action_pos_order_invoice']" position='after'>
                    <field name="is_send" invisible="1"/>
                    <button name="send_mail_invoice" string="Send By Email" type="object" invisible="state not in ['invoiced','paid'] or is_send"/>
                </xpath>
            </field>
        </record>
	</data>
</odoo>