<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>


        <record id="view_purchase_order_form_crossdock" model="ir.ui.view">
            <field name="name">purchase.order.form.crossdock</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
        
                <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                        <button invisible="state in ('draft', 'cancel')" name="llamarComponente" type="object" class="oe_stat_button" string="Editar distribucion"/>
                </xpath>

                <xpath expr="//group[@name='invoice_info']" position="after">
                    <group string="Configuración Crossdocking">
                        <field name="crossdock_enabled"/>
                        <field name="crossdock_percentage"/>
                        <field name="distribution_rounding_method"/>
                    </group>
                </xpath>

                <xpath expr="//field[@name='product_qty']" position="after">
                    <field name="use_crossdock"/>
                    <field name="line_crossdock_percentage" widget="percentage" invisible="not use_crossdock"/>
                    <field name="distribution_multiple" invisible="not use_crossdock"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>