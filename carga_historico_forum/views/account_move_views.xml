<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista de formulario de factura - Agregar campos de migración en el encabezado -->
        <record id="view_move_form_inherit_migration_fields" model="ir.ui.view">
            <field name="name">account.move.form.inherit.migration.fields</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="priority" eval="99"/>
            <field name="arch" type="xml">
                <!-- Agregar campos de migración después del campo partner_id -->
                <xpath expr="//field[@name='partner_id']" position="after">
                    <group>
                        <group>
                            <field name="x_mig_source" invisible="1"/>
                            <field name="x_mig_source_document_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="x_mig_partner_code" invisible="1"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- Vista de líneas de factura - Agregar campos de migración en las líneas -->
        <record id="view_move_line_tree_inherit_migration_fields" model="ir.ui.view">
            <field name="name">account.move.line.tree.inherit.migration.fields</field>
            <field name="model">account.move.line</field>
            <field name="inherit_id" ref="account.view_move_line_tree"/>
            <field name="priority" eval="99"/>
            <field name="arch" type="xml">
                <!-- Agregar columnas de migración en la vista de árbol -->
                <!-- Insertamos columnas adicionales junto a información monetaria existente.
                     En la vista base no existe el campo 'price_unit', por eso usamos 'balance'
                     como ancla segura. -->
                <xpath expr="//field[@name='product_id']" position="after">
                    <field name="x_mig_product_sku" optional="hide"/>
                    <field name="x_mig_product_name" optional="hide"/>
                </xpath>
                <xpath expr="//field[@name='balance']" position="after">
                    <field name="x_mig_operational_cost" optional="hide"/>
                    <field name="x_mig_standard_cost_snapshot" optional="hide"/>
                </xpath>
            </field>
        </record>

        <!-- Vista de formulario de líneas de factura - Agregar campos de migración -->
        <record id="view_move_line_form_inherit_migration_fields" model="ir.ui.view">
            <field name="name">account.move.line.form.inherit.migration.fields</field>
            <field name="model">account.move.line</field>
            <field name="inherit_id" ref="account.view_move_line_form"/>
            <field name="priority" eval="99"/>
            <field name="arch" type="xml">
                <!-- Agregar campos de migración en la pestaña o sección apropiada -->
                <xpath expr="//field[@name='product_id']" position="after">
                    <group>
                        <group string="Información de Migración - Producto">
                            <field name="x_mig_product_sku"/>
                            <field name="x_mig_product_name"/>
                        </group>
                        <group string="Snapshots Históricos">
                            <field name="x_mig_product_tags_snapshot" widget="text"/>
                            <field name="x_mig_price_group_snapshot_id"/>
                            <field name="x_mig_price_group_snapshot"/>
                        </group>
                    </group>
                    <group string="Costos para Reportes">
                        <group>
                            <field name="x_mig_operational_cost"/>
                            <field name="x_mig_standard_cost_snapshot"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

