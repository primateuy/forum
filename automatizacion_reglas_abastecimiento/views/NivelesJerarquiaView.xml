<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vista Tree -->
    <record model="ir.ui.view" id="automatizacion_reglas_abastecimiento.tree">
        <field name="name">niveles.jerarquia.tree</field>
        <field name="model">niveles.jerarquia</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="nombre"/>
                <field name="seq"/>
                <field name="grupos_id" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <!-- Vista Form -->
    <record model="ir.ui.view" id="automatizacion_reglas_abastecimiento.form">
        <field name="name">niveles.jerarquia.form</field>
        <field name="model">niveles.jerarquia</field>
        <field name="arch" type="xml">
            <form string="Niveles de Jerarquía">
                <sheet>
                    <group>
                        <field name="nombre"/>
                        <field name="seq"/>
                        <field name="grupos_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_niveles_jerarquias" model="ir.actions.act_window">
        <field name="name">Niveles de Jerarquía</field>
        <field name="res_model">niveles.jerarquia</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_niveles_jerarquia"
          name="Niveles de Jerarquía"
          parent="setu_advance_reordering.menu_sub_reorder_configuration"
          sequence="6"
          action="action_niveles_jerarquias"
          />

</odoo>
