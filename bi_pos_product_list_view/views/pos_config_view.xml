<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Custom Fields in pos.config -->
    <record model="ir.ui.view" id="pos_config_settings_multi_currency">
        <field name="name">res.config.setting.pos.multi.currency.form.view</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_interface_section']" position="inside">
                <div id="pos_product_view_option" class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane">
                        <field name="pos_enable_list_view"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="pos_enable_list_view" string="Enable List View"/>
                        <div class="content-group mt16" invisible="pos_enable_list_view == False">
                            <div>
                                <field name="pos_display_product_name" class="oe_inline"/>
                                <label for="pos_display_product_name" string="Display Product Name"
                                    class="oe_inline"/>
                            </div>
                            <div>
                                <field name="pos_display_product_type" class="oe_inline"/>
                                <label for="pos_display_product_type" string="Display Product Type"
                                    class="oe_inline"/>
                            </div>
                            <div>
                                <field name="pos_display_product_code" class="oe_inline"/>
                                <label for="pos_display_product_code" string="Display Product Reference Code"
                                    class="oe_inline"/>
                            </div>
                            <div>
                                <field name="pos_display_product_UOM" class="oe_inline"/>
                                <label for="pos_display_product_UOM" string="Display Product UOM"
                                    class="oe_inline"/>
                            </div>
                            <div>
                                <field name="pos_display_product_price" class="oe_inline"/>
                                <label for="pos_display_product_price" string="Display Product Price"
                                    class="oe_inline"/>
                            </div>
                            <div>
                                <field name="pos_display_product_on_hand_qty" class="oe_inline"/>
                                <label for="pos_display_product_on_hand_qty" string="Display Product On Hand Qty"
                                    class="oe_inline"/>
                            </div>
                            <div>
                                <field name="pos_display_product_forecast_qty" class="oe_inline"/>
                                <label for="pos_display_product_forecast_qty" string="Display Product Forecast Qty"
                                    class="oe_inline"/>
                            </div>
                            <div>
                                <field name="pos_display_product_image" class="oe_inline"/>
                                <label for="pos_display_product_image" string="Display Product Image"
                                    class="oe_inline"/>
                            </div>
                            <div invisible="pos_display_product_image == False">
                                <field name="pos_image_size" class="oe_inline" widget="radio"/>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6 o_setting_box" invisible = "pos_enable_list_view == False">
                    <div class="o_setting_right_pane">
                        <span class="o_form_label">Default Product View</span>
                        <div class="content-group mt16 row" style="margin-left: 10px;">
                            <field name="pos_prod_view" widget="radio"/>
                        </div>
                    </div>
                </div> 
            </xpath>
            <xpath expr="//block[@id='pos_inventory_section']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_left_pane">
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="pos_product_ordering" string="POS Product Arrangement"/>
                        <div class="text-muted">
                             Use Arrangement Sequence A-Z, Z-A, Low Price, High Price, etc.
                        </div>
                        <div class="content-group mt16">
                            <div>
                                <label for="pos_product_ordering" string="Arrangement Sequences"
                                       style="font-weight: 500;width: 95px;" class="o_form_label col-lg-3 o_light_label"/>
                                <field name="pos_product_ordering" class="oe_inline"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
