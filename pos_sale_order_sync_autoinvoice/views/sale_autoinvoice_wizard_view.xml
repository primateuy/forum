<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_autoinvoice_wizard_form" model="ir.ui.view">
        <field name="name">sale.autoinvoice.wizard.form</field>
        <field name="model">sale.autoinvoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Facturar por límite de líneas">
                <sheet>
                    <group>
                        <field name="warning_message" widget="text" nolabel="1"
                               style="font-size: 13px; padding: 8px;"/>
                    </group>
                    <group string="Detalle" invisible="not has_exclusions">
                        <group>
                            <field name="lines_to_invoice" string="Líneas a facturar"/>
                            <field name="lines_excluded" string="Líneas excluidas"/>
                        </group>
                        <group>
                            <field name="max_lineas" string="Límite del punto de emisión"/>
                            <field name="orders_excluded_count" string="Órdenes excluidas"/>
                        </group>
                    </group>
                    <group string="Órdenes excluidas" invisible="not has_exclusions">
                        <field name="orders_excluded_ids" nolabel="1" widget="many2many_tags" readonly="1"/>
                    </group>
                    <field name="has_exclusions" invisible="1"/>
                </sheet>
                <footer>
                    <button name="action_create_invoice" type="object"
                            string="Generar Factura" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Acción de servidor desde la vista lista de órdenes de venta -->
    <data noupdate="0">
        <record id="action_sale_autoinvoice_by_limit" model="ir.actions.server">
            <field name="name">Facturar por límite de líneas</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="binding_view_types">list</field>
            <field name="groups_id" eval="[(4, ref('pos_sale_order_sync_autoinvoice.group_facturacion_franquicias'))]"/>
            <field name="state">code</field>
            <field name="code">action = records.action_autoinvoice_by_limit()</field>
        </record>
    </data>
</odoo>
