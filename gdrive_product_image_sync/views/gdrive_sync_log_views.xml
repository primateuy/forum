<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree view -->
    <record id="gdrive_sync_log_view_tree" model="ir.ui.view">
        <field name="name">gdrive.sync.log.tree</field>
        <field name="model">gdrive.sync.log</field>
        <field name="arch" type="xml">
            <tree decoration-success="status == 'ok'"
                  decoration-warning="status == 'warning'"
                  decoration-danger="status == 'error'">
                <field name="sync_date"/>
                <field name="name"/>
                <field name="sku"/>
                <field name="status"/>
                <field name="message"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="gdrive_sync_log_view_form" model="ir.ui.view">
        <field name="name">gdrive.sync.log.form</field>
        <field name="model">gdrive.sync.log</field>
        <field name="arch" type="xml">
            <form string="Sync Log Entry" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sku"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="sync_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="gdrive_sync_log_action" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">gdrive.sync.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu under Settings -->
    <menuitem id="gdrive_sync_log_menu"
              name="GDrive Sync Logs"
              action="gdrive_sync_log_action"
              parent="base.menu_administration"
              sequence="90"/>

</odoo>
