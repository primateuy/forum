<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
        <!-- Agregar columnas a la vista tree de líneas de compra -->
        <record id="view_purchase_order_line_tree_crossdock" model="ir.ui.view">
            <field name="name">purchase.order.type.tree.crossdock</field>
            <field name="model">purchase.order.type</field>
            <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='product_qty']" position="after">
                    <field name="use_crossdock"/>
                    <field name="line_crossdock_percentage"/>
                    <field name="distribution_multiple"/>
                </xpath>
            </field>
        </record>
    </data>

</odoo>
