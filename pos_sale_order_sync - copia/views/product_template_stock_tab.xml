<?xml version="1.0"?>
<odoo>
    <record id="product_template_form_inventory_tab" model="ir.ui.view">
        <field name="name">product_template_form_inventory_tab</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_lots_and_weight']" position="inside">
                <field name="excluir_logica_franquicia"/>
            </xpath>
        </field>
    </record>
</odoo>
