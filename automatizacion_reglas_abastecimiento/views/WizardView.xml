<odoo>
    <record id="view_stock_warehouse_group_rules_wizard_form" model="ir.ui.view">
        <field name="name">stock.warehouse.group.rules.wizard.form</field>
        <field name="model">stock.warehouse.group.rules.wizard</field>
        <field name="arch" type="xml">
            <form string="Actualizar Reglas de Abastecimiento">
                <group>
                    <field name="warehouse_group_id" readonly="1"/>
                    <field name="available_warehouse_ids" invisible="1"/>
                    <field name="warehouse_ids" 
                        widget="many2many_tags" 
                        options="{'no_create': True, 'no_open': True}"
                        domain="[('id', 'in', available_warehouse_ids)]"
                        placeholder="Seleccione los almacenes del grupo..."/>
                </group>
                <footer>
                    <button name="actualizarReglas" 
                            string="Actualizar Reglas" 
                            type="object" 
                            class="btn-primary"/>
                    <button string="Cancelar" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>