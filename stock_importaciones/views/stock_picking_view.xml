<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_import" model="ir.ui.view">
        <field name="model">stock.picking</field>
        <field name="name">stock.picking.form_import</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header//field[@name='state']" position="before">
                <field name="is_import_op" invisible="1"/>

                <button name="action_toggle_import_status"
                        invisible="state == 'draft' or is_import_op == False or import_op_status == 'open' or import_op_status == ''"
                        string="Abrir" groups="stock_importaciones.open_close_imports"
                        type="object"
                        help="Abre la Operación."/>

                <button name="action_toggle_import_status"
                        confirm='Va a cerrar la Transferencia. Esta ya no estará disponible para Costes en Destino. Desea continuar?'
                        invisible="state == 'draft' or is_import_op == False or import_op_status == 'closed' or import_op_status == ''"
                        string="Cerrar" class="oe_highlight"
                        groups="stock_importaciones.open_close_imports"
                        type="object"
                        help="Cierra la Operación."/>

            </xpath>
            <xpath expr="//field[@name='location_dest_id']" position="after">
                <field name="import_op_status" string="Estado de la Carpeta" invisible="is_import_op == False" readonly="1"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_see_transfers" string="Costes en destino" type="object"
                        class="oe_stat_button" icon="fa-plus-square"/>
            </xpath>

        </field>
    </record>

<!--    <xpath expr="//div[@name='button_box']" position="inside">
        <field name="landed_costs_ids" invisible="1"/>
        <button string="Landed Costs" type="object" name="action_view_landed_costs" class="oe_stat_button"
                icon="fa-plus-square" groups="stock.group_stock_manager"
                attrs="{'invisible': [('landed_costs_ids', '=', [])]}"/>
    </xpath>-->
</odoo>