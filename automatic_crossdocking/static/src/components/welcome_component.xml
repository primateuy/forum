<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="crossdock_distribution_template">
        <div t-if="!state.loading" class="table-responsive p-6">
            <table class="table p-4">
                <thead>
                    <tr>
                        <t t-foreach="state.distributionData.columns" t-as="col" t-key="col.key">
                            <th t-if="col.key !== 'picking_id'">
                                <t t-esc="col.label"/>
                            </th>
                        </t>
                        
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="state.distributionData.rows" t-as="row" t-key="row.product_name">
                        <tr>
                            <t t-foreach="state.distributionData.columns" t-as="col" t-key="col.key">
                                <td t-if="col.key != 'picking_id'">


                                    <input t-if="col.key === 'main_reception'"
                                           type="number"
                                           class="o_input o_field_number"
                                           t-att-data-picking-id="row.main_reception_picking_id"
                                           t-att-data-product-id="row.product_id"
                                           t-att-data-pedido="row.pedido"
                                           t-att-value="row[col.key]"
                                           t-on-change="(ev) => this.onInputChange(ev, row, col)"
                                    />

                                    <!-- Otras columnas editables -->
                                    <input t-if="col.key !== 'product_name' and col.key !== 'pedido' and col.key !== 'crossdock' and col.key !== 'main_reception'"
                                           type="number"
                                           class="o_input o_field_number"
                                           t-att-data-picking-id="row.picking_id"
                                           t-att-data-product-id="row.product_id"
                                           t-att-data-pedido="row.pedido"
                                           t-att-value="row[col.key]"
                                           t-on-change="(ev) => this.onInputChange(ev, row, col)"
                                    />
                                    
                                    <!-- Campos de solo lectura para pedido y crossdock -->
                                    <input t-if="col.key === 'pedido' or col.key === 'crossdock'"
                                           type="number"
                                           class="o_input o_field_number"
                                           t-att-value="row[col.key]"
                                           disabled="disabled"
                                           style="background-color: #f8f9fa; cursor: not-allowed;"
                                    />
                                    <span t-if="col.key === 'product_name'">
                                        <t t-esc="row[col.key]"/>
                                    </span>
                                </td>
                            </t>
                        </tr>
                    </t>
                </tbody>
            </table>
        </div>
    </t>
</templates>