<?xml version="1.0"?>
<odoo>
    <record id="punto_emision_form" model="ir.ui.view">
        <field name="name">punto_emision_form</field>
        <field name="model">dgi.punto.emision</field>
        <field name="inherit_id" ref="l10n_uy_einvoice_base.view_dgi_punto_emision_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <label for="max_numero_lineas" string="Cantidad máxima de líneas"/>
                <field name="max_numero_lineas"/>
            </xpath>
        </field>
    </record>
</odoo>
